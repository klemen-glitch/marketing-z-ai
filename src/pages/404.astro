---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 – Stran ni najdena"
  description="Stran, ki jo iščete, ne obstaja. Vrnite se na marketingzai.eu"
>
  <main class="min-h-screen flex items-center justify-center px-4 text-center">
    <!-- Glow orb -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-neon-cyan/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-lg mx-auto">
      <!-- Glitch number -->
      <div class="relative mb-6">
        <p class="text-[10rem] leading-none font-black text-transparent bg-gradient-to-br from-neon-cyan via-neon-purple to-neon-pink bg-clip-text select-none glitch-text" data-text="404">
          404
        </p>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-32 h-0.5 bg-gradient-to-r from-neon-cyan to-neon-purple rounded-full opacity-60"></div>
        </div>
      </div>

      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-4">
        Ta stran ne obstaja
      </h1>
      <p class="text-gray-400 mb-10 leading-relaxed">
        Morda je bila stran premaknjena, izbrisana ali ste vtipkali napačen naslov.
        Naši AI agenti jo iščejo, a zaenkrat brez uspeha.
      </p>

      <!-- Action buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="px-8 py-3 bg-gradient-to-r from-neon-cyan to-neon-blue rounded-xl font-bold text-dark-bg hover:shadow-lg hover:shadow-neon-cyan/40 transition-all duration-300 hover:scale-105"
        >
          ← Nazaj na začetek
        </a>
        <a
          href="/#kontakt"
          class="px-8 py-3 border border-neon-cyan/40 rounded-xl font-semibold text-neon-cyan hover:bg-neon-cyan/10 transition-all duration-300"
        >
          Kontaktiraj nas
        </a>
      </div>

      <!-- Mini agent icon -->
      <div class="mt-16 flex items-center justify-center gap-3 text-gray-600 text-sm">
        <svg width="20" height="20" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="opacity-40">
          <rect x="8" y="12" width="24" height="20" rx="4" fill="#00f0ff" opacity="0.3"/>
          <rect x="14" y="8" width="12" height="8" rx="2" fill="#00f0ff" opacity="0.4"/>
          <circle cx="15" cy="21" r="3" fill="#00f0ff" opacity="0.8"/>
          <circle cx="25" cy="21" r="3" fill="#00f0ff" opacity="0.8"/>
          <rect x="16" y="26" width="8" height="2" rx="1" fill="#00f0ff" opacity="0.6"/>
        </svg>
        <span>Marketing z AI · marketingzai.eu</span>
      </div>
    </div>
  </main>
</Layout>

<style>
  .glitch-text {
    position: relative;
    animation: glitch 4s infinite;
  }
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    background: inherit;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }
  .glitch-text::before {
    animation: glitch-top 4s infinite;
    clip-path: polygon(0 0, 100% 0, 100% 40%, 0 40%);
    transform: translateX(-2px);
  }
  .glitch-text::after {
    animation: glitch-bottom 4s infinite;
    clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%);
    transform: translateX(2px);
  }
  @keyframes glitch {
    0%, 90%, 100% { transform: translate(0); }
    92% { transform: translate(-1px, 1px); }
    94% { transform: translate(1px, -1px); }
    96% { transform: translate(0); }
  }
  @keyframes glitch-top {
    0%, 90%, 100% { opacity: 0; }
    92% { opacity: 0.6; transform: translateX(-3px); filter: hue-rotate(90deg); }
    94% { opacity: 0; }
  }
  @keyframes glitch-bottom {
    0%, 90%, 100% { opacity: 0; }
    93% { opacity: 0.5; transform: translateX(3px); filter: hue-rotate(-90deg); }
    95% { opacity: 0; }
  }
</style>
