---
---

<section class="py-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-neon-purple/10 rounded-full blur-3xl opacity-20"></div>
  </div>

  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-4xl sm:text-5xl font-bold mb-6">
          <span class="bg-gradient-to-r from-neon-cyan to-neon-blue bg-clip-text text-transparent">
            Pokličimo za brezplačno konzultacijo
          </span>
        </h2>
        <p class="text-xl text-gray-400 mb-8">
          Razgovarjajmo o vašem trenutnem stanju in kako vam lahko pomagamo doseči vaše cilje z AI in avtomatizacijo.
        </p>

        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="text-2xl">📧</div>
            <div>
              <div class="font-semibold text-white">Email</div>
              <div class="text-gray-400">klemenlor@gmail.com</div>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="text-2xl">📱</div>
            <div>
              <div class="font-semibold text-white">Telefon</div>
              <div class="text-gray-400">040 352 112</div>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="text-2xl">📍</div>
            <div>
              <div class="font-semibold text-white">Lokacija</div>
              <div class="text-gray-400">Ljubljana, Slovenija</div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-neon-cyan/20 to-neon-purple/20 rounded-2xl blur-xl"></div>
        <form
          name="kontakt"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          id="contact-form"
          class="relative bg-[#1a1f3a] border border-[#2d3561] rounded-2xl p-8"
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="kontakt" />
          <p class="hidden"><input name="bot-field" /></p>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white" for="ime">Ime in Priimek <span class="text-neon-pink">*</span></label>
            <input
              type="text"
              id="ime"
              name="ime"
              required
              placeholder="Vaše ime"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors"
            />
          </div>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white" for="email">Email <span class="text-neon-pink">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="vas@email.com"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors"
            />
          </div>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white" for="podjetje">Podjetje</label>
            <input
              type="text"
              id="podjetje"
              name="podjetje"
              placeholder="Ime podjetja"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors"
            />
          </div>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white" for="sporocilo">Vaše sporočilo <span class="text-neon-pink">*</span></label>
            <textarea
              id="sporocilo"
              name="sporocilo"
              required
              placeholder="Povejte nam, s čim se ukvarjate in kako vam lahko pomagamo..."
              rows="4"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Success message -->
          <div id="form-success" class="hidden mb-4 p-4 rounded-lg bg-neon-lime/10 border border-neon-lime/30 text-neon-lime text-sm font-semibold text-center">
            ✅ Sporočilo poslano! Odgovorili bomo v 24 urah.
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-3 px-6 bg-gradient-to-r from-neon-cyan to-neon-blue rounded-lg font-bold text-[#0a0e27] hover:shadow-lg hover:shadow-neon-cyan/50 transition-all duration-300 transform hover:scale-105"
          >
            Pošlji povpraševanje →
          </button>
          <p class="text-xs text-gray-600 text-center mt-3">Z oddajo se strinjate z našo <a href="/privacy-policy" class="text-gray-500 hover:text-neon-cyan underline">politiko zasebnosti</a>.</p>
        </form>

        <script>
          const form = document.getElementById('contact-form') as HTMLFormElement;
          const successMsg = document.getElementById('form-success');
          const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

          form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitBtn.textContent = 'Pošiljam...';
            submitBtn.disabled = true;

            try {
              const formData = new FormData(form);
              const response = await fetch('/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams(formData as any).toString(),
              });

              if (response.ok) {
                successMsg?.classList.remove('hidden');
                form.reset();
                submitBtn.textContent = '✅ Poslano!';
              } else {
                submitBtn.textContent = 'Pošlji povpraševanje →';
                submitBtn.disabled = false;
              }
            } catch {
              submitBtn.textContent = 'Pošlji povpraševanje →';
              submitBtn.disabled = false;
            }
          });
        </script>
      </div>
    </div>
  </div>
</section>
