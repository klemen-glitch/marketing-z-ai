---
---

<footer class="border-t border-[#2d3561]/50 bg-gradient-to-b from-dark-bg to-dark-bg/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div>
        <h3 class="text-lg font-bold mb-4 text-neon-cyan">Astra AI</h3>
        <p class="text-gray-400 text-sm">
          Povezovalna moč med ljudmi in umetno inteligenco za hitrejšo rast vašega poslovanja.
        </p>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-white">Storitve</h4>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Meta Lead Gen</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Google Ads</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">CRM Integracije</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">AI Agenti</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-white">Viri</h4>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Learning Hub</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Blog</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Dokumentacija</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Primeri</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-white">Podjetje</h4>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li><a href="#" class="hover:text-neon-cyan transition-colors">O nas</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Pogoji uporabe</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Politika zasebnosti</a></li>
          <li><a href="#" class="hover:text-neon-cyan transition-colors">Kontakt</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[#2d3561]/50 pt-8 flex flex-col md:flex-row justify-between items-center">
      <div class="text-gray-500 text-sm mb-4 md:mb-0">
        © 2026 Astra AI. Powered by Klemen Lorber & Whole Design Studios.
      </div>
      <div class="flex gap-4">
        <a href="#" class="text-gray-400 hover:text-neon-cyan transition-colors">LinkedIn</a>
        <a href="#" class="text-gray-400 hover:text-neon-cyan transition-colors">Twitter</a>
        <a href="#" class="text-gray-400 hover:text-neon-cyan transition-colors">GitHub</a>
      </div>
    </div>
  </div>
</footer>
