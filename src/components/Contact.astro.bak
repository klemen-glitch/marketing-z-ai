---
---

<section class="py-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-neon-purple/10 rounded-full blur-3xl opacity-20"></div>
  </div>

  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-4xl sm:text-5xl font-bold mb-6">
          <span class="bg-gradient-to-r from-neon-cyan to-neon-blue bg-clip-text text-transparent">
            Pokličimo za brezplačno konzultacijo
          </span>
        </h2>
        <p class="text-xl text-gray-400 mb-8">
          Razgovarjajmo o vašem trenutnem stanju in kako vam lahko pomagamo doseči vaše cilje z AI in avtomatizacijo.
        </p>

        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="text-2xl">📧</div>
            <div>
              <div class="font-semibold text-white">Email</div>
              <div class="text-gray-400">hello@astrai.com</div>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="text-2xl">📱</div>
            <div>
              <div class="font-semibold text-white">Telefon</div>
              <div class="text-gray-400">+386 1 200 0000</div>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="text-2xl">📍</div>
            <div>
              <div class="font-semibold text-white">Lokacija</div>
              <div class="text-gray-400">Ljubljana, Slovenija</div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-neon-cyan/20 to-neon-purple/20 rounded-2xl blur-xl"></div>
        <form class="relative bg-[#1a1f3a] border border-[#2d3561] rounded-2xl p-8">
          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white">Ime in Priimek</label>
            <input
              type="text"
              placeholder="Vaše ime"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors"
            />
          </div>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white">Email</label>
            <input
              type="email"
              placeholder="vas@email.com"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors"
            />
          </div>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white">Podjetje</label>
            <input
              type="text"
              placeholder="Ime podjetja"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors"
            />
          </div>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-white">Vaše sporočilo</label>
            <textarea
              placeholder="Povejte nam, s čim se ukvarjate..."
              rows="4"
              class="w-full px-4 py-3 bg-[#0a0e27] border border-[#2d3561] rounded-lg focus:outline-none focus:border-neon-cyan text-white placeholder-gray-600 transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-3 px-6 bg-gradient-to-r from-neon-cyan to-neon-blue rounded-lg font-bold text-dark-bg hover:shadow-lg hover:shadow-neon-cyan/50 transition-all duration-300 transform hover:scale-105"
          >
            Pošlji povpraševanje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
