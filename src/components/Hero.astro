---
---

<section class="relative min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 py-20">
  <!-- Animated background orbs -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-96 h-96 bg-neon-cyan/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-1/4 w-64 h-64 bg-neon-purple/20 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center">
    <!-- Badge -->
    <div class="mb-8 inline-block px-4 py-2 bg-dark-card border border-neon-cyan/30 rounded-full backdrop-blur-sm">
      <span class="text-neon-cyan text-sm font-semibold">🚀 Prihodnost marketinga je tu</span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-7xl font-bold mb-6 leading-tight">
      <span class="animate-glow bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-pink bg-clip-text text-transparent inline-block">
        AI Agenti
      </span>
      <br />
      <span class="text-white">kot vaš marketing partner</span>
    </h1>

    <p class="text-xl sm:text-2xl text-gray-300 mb-12 max-w-2xl mx-auto leading-relaxed">
      Povezovalna moč med ljudmi in umetno inteligenco. Skupaj rastemo hitrejše, pametnejše in bolj učinkovito.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-20">
      <a href="#storitve" class="px-8 py-4 bg-gradient-to-r from-neon-cyan to-neon-blue rounded-lg font-bold text-dark-bg hover:shadow-lg hover:shadow-neon-cyan/50 transition-all duration-300 transform hover:scale-105 text-center">
        Spoznaj storitve
      </a>
      <a href="#kontakt" class="px-8 py-4 bg-dark-card border-2 border-neon-purple text-neon-purple rounded-lg font-bold hover:bg-neon-purple/10 transition-all duration-300 text-center">
        Brezplačna konzultacija
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl bg-dark-card/50 border border-dark-border hover:border-neon-cyan/50 transition-colors duration-300">
        <div class="text-4xl font-bold text-neon-cyan mb-1">1 + 6</div>
        <div class="text-gray-400 text-sm">Strokovnjak & AI agenti</div>
      </div>
      <div class="p-6 rounded-xl bg-dark-card/50 border border-dark-border hover:border-neon-purple/50 transition-colors duration-300">
        <div class="text-4xl font-bold text-neon-purple mb-1">771%</div>
        <div class="text-gray-400 text-sm">ROI za integracije</div>
      </div>
      <div class="p-6 rounded-xl bg-dark-card/50 border border-dark-border hover:border-neon-pink/50 transition-colors duration-300">
        <div class="text-4xl font-bold text-neon-pink mb-1">11 let</div>
        <div class="text-gray-400 text-sm">Izkušenj v branži</div>
      </div>
    </div>
  </div>
</section>
