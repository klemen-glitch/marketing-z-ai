      <!-- Helmet rogi/antene -->
      <path d="M18 10 L10 0 L16 4 L18 10" fill="#ff006e" opacity="0.7"/>
      <path d="M82 10 L90 0 L84 4 L82 10" fill="#ff006e" opacity="0.7"/>
      <!-- Stranki ventilatorji -->
      <rect x="4" y="24" width="10" height="24" rx="2" fill="#0d1226" stroke="#ff006e" stroke-width="1"/>
      <rect x="86" y="24" width="10" height="24" rx="2" fill="#0d1226" stroke="#ff006e" stroke-width="1"/>
      <line x1="4" y1="30" x2="14" y2="30" stroke="#ff006e" stroke-width="0.8" opacity="0.5"/>
      <line x1="4" y1="36" x2="14" y2="36" stroke="#ff006e" stroke-width="0.8" opacity="0.5"/>
      <line x1="4" y1="42" x2="14" y2="42" stroke="#ff006e" stroke-width="0.8" opacity="0.5"/>
      <line x1="86" y1="30" x2="96" y2="30" stroke="#ff006e" stroke-width="0.8" opacity="0.5"/>
      <line x1="86" y1="36" x2="96" y2="36" stroke="#ff006e" stroke-width="0.8" opacity="0.5"/>
      <line x1="86" y1="42" x2="96" y2="42" stroke="#ff006e" stroke-width="0.8" opacity="0.5"/>
    </svg>`
  },
  {
    id: "AG-06",
    name: "Call Agent",
    role: "Transkripcija & Analiza",
    description: "Posluša vsak klic, prepiše besede in izvleče ključne točke, sentiment in akcijske naloge – takoj po klicu v CRM.",
    borderColor: "#00d4ff",
    glowColor: "rgba(0, 212, 255, 0.3)",
    stats: ["96% točnost", "Sentiment AI", "Auto CRM"],
    svg: `<svg viewBox="0 0 100 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Telo - sleek, acoustic design -->
      <ellipse cx="50" cy="98" rx="24" ry="22" fill="#0d1226" stroke="#00d4ff" stroke-width="1.5"/>
      <!-- Sound wave pattern na telesu -->
      <path d="M30 96 Q38 90 50 96 Q62 102 70 96" stroke="#00d4ff" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.6"/>
      <path d="M34 102 Q42 97 50 102 Q58 107 66 102" stroke="#00d4ff" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.4"/>
      <!-- Mic element na prsih -->
      <rect x="46" y="90" width="8" height="14" rx="4" fill="#0d1226" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="42" y1="108" x2="58" y2="108" stroke="#00d4ff" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="50" y1="104" x2="50" y2="108" stroke="#00d4ff" stroke-width="1.5"/>
      <!-- Roke - slušalke/headset cables -->
      <path d="M26 82 Q12 78 10 92 L10 108 Q10 114 16 116 L24 116" stroke="#00d4ff" stroke-width="2" fill="none" stroke-linecap="round"/>
      <path d="M74 82 Q88 78 90 92 L90 108 Q90 114 84 116 L76 116" stroke="#00d4ff" stroke-width="2" fill="none" stroke-linecap="round"/>
      <!-- Headset earpiece -->
      <rect x="6" y="88" width="12" height="22" rx="6" fill="#0d1226" stroke="#00d4ff" stroke-width="2"/>
      <rect x="82" y="88" width="12" height="22" rx="6" fill="#0d1226" stroke="#00d4ff" stroke-width="2"/>
      <circle cx="12" cy="99" r="5" fill="#00d4ff" opacity="0.3"/>
      <circle cx="88" cy="99" r="5" fill="#00d4ff" opacity="0.3"/>
      <circle cx="12" cy="99" r="2" fill="#00d4ff" opacity="0.8"/>
      <circle cx="88" cy="99" r="2" fill="#00d4ff" opacity="0.8"/>
      <!-- Glava - ovoid, smooth -->
      <ellipse cx="50" cy="40" rx="34" ry="38" fill="#0d1226" stroke="#00d4ff" stroke-width="2"/>
      <!-- Headset arc čez glavo -->
      <path d="M16 40 C16 10 84 10 84 40" stroke="#00d4ff" stroke-width="3" fill="none"/>
      <!-- Vizir - cel oval -->
      <ellipse cx="50" cy="42" rx="26" ry="18" fill="#00d4ff" opacity="0.05" stroke="#00d4ff" stroke-width="1.5"/>
      <!-- Oči - horizontalni scan bars -->
      <rect x="22" y="34" width="20" height="12" rx="2" fill="#001a26" stroke="#00d4ff" stroke-width="1.5"/>
      <rect x="58" y="34" width="20" height="12" rx="2" fill="#001a26" stroke="#00d4ff" stroke-width="1.5"/>
      <!-- Audio visualizer v očeh -->
      <line x1="25" y1="43" x2="25" y2="37" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="28" y1="44" x2="28" y2="36" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="31" y1="42" x2="31" y2="38" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="34" y1="43" x2="34" y2="37" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="37" y1="44" x2="37" y2="36" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="61" y1="43" x2="61" y2="37" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="64" y1="44" x2="64" y2="36" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="67" y1="42" x2="67" y2="38" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="70" y1="43" x2="70" y2="37" stroke="#00d4ff" stroke-width="1.5"/>
      <line x1="73" y1="44" x2="73" y2="36" stroke="#00d4ff" stroke-width="1.5"/>
